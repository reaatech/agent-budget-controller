{
  "name": "agent-budget-controller",
  "version": "0.0.0",
  "private": true,
  "description": "Real-time cost budget enforcement for agent systems",
  "keywords": [
    "agent",
    "budget",
    "cost",
    "llm",
    "openai",
    "anthropic",
    "enforcement",
    "middleware"
  ],
  "homepage": "https://github.com/reaatech/agent-budget-controller#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agent-budget-controller/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/agent-budget-controller.git"
  },
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo",
    "dev": "tsc -b --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && pnpm run test && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.17.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
