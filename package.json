{
  "name": "agent-budget-controller",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time cost budget enforcement for agent systems",
  "keywords": [
    "agent",
    "budget",
    "cost",
    "llm",
    "openai",
    "anthropic",
    "enforcement",
    "middleware"
  ],
  "homepage": "https://github.com/reaatech/agent-budget-controller#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agent-budget-controller/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/agent-budget-controller.git"
  },
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "turbo run test",
    "test:watch": "vitest",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.28.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "3.2.4",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
