{
  "name": "@reaatech/agent-budget-cli",
  "version": "0.1.0",
  "description": "CLI for agent-budget-controller",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/agent-budget-controller.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/reaatech/agent-budget-controller/issues"
  },
  "homepage": "https://github.com/reaatech/agent-budget-controller#readme",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-budget": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@reaatech/agent-budget-types": "workspace:*",
    "@reaatech/agent-budget-engine": "workspace:*",
    "@reaatech/agent-budget-spend-tracker": "workspace:*",
    "@reaatech/agent-budget-pricing": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
